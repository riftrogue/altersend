# Sentry DSN for the Electron main process (native crash reporting)
SENTRY_DSN=

# Sentry DSN for the renderer process (JS errors, transfer failures)
# Must be prefixed VITE_ to be exposed to the renderer via import.meta.env
VITE_SENTRY_DSN=

# Discord webhook URL for in-app feedback submissions (optional)
# Must be prefixed VITE_ to be exposed to the renderer via import.meta.env
VITE_DISCORD_WEBHOOK_URL=
