{
  "appId": "com.altersend.desktop",
  "electronVersion": "40.2.1",
  "icon": "build/icon.ico",
  "asar": false,
  "directories": {
    "output": "out"
  },
  "files": [
    "dist/**/*",
    "package.json",
    "!dist/**/*.map",
    "!**/node_modules/react-native/**",
    "!**/node_modules/react-native-*/**",
    "!**/node_modules/@react-native/**",
    "!**/node_modules/@expo/**",
    "!**/node_modules/expo-*/**",
    "!**/node_modules/metro*/**",
    "!**/node_modules/jest*/**",
    "!**/node_modules/@jest/**",
    "!**/node_modules/@babel/**",
    "!**/node_modules/babel-*/**"
  ],
  "win": {
    "icon": "build/icon.ico",
    "target": ["portable"],
    "artifactName": "${productName}-${version}-Portable-${arch}.${ext}"
  },
  "portable": {
    "artifactName": "${productName}-${version}-Portable-${arch}.${ext}"
  },
  "afterPack": "scripts/afterPack.cjs"
}
