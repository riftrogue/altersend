{
  "name": "@altersend/desktop",
  "productName": "AlterSend",
  "version": "1.5.1",
  "upgrade": "pear://w5u4xqsncqyfhb1owdqogr3mpg6b5tcdzn65pk88ispgew5jegso",
  "description": "Peer-to-peer file transfer. No servers, no accounts.",
  "license": "Apache-2.0",
  "author": "AlterSend",
  "type": "module",
  "main": "dist/electron/main.js",
  "private": true,
  "scripts": {
    "build": "node scripts/gen-env.cjs && tsc -p src/tsconfig.electron.json && node scripts/copy-preload.cjs && vite build",
    "build:electron": "node scripts/gen-env.cjs && tsc -p src/tsconfig.electron.json",
    "build:renderer": "vite build",
    "typecheck": "tsc --noEmit -p src/tsconfig.electron.json && tsc --noEmit -p tsconfig.json",
    "start": "npm run build && electron-forge start -- --no-updates",
    "start:peer2": "npm run build && electron-forge start -- --no-updates --multi --storage=../../storage-2",
    "start:peer3": "npm run build && electron-forge start -- --no-updates --multi --storage=../../storage-3",
    "dist:prepare:dev": "npm install && npm run build && npm prune --omit=dev && npm install electron --no-save",
    "dist:mac:arm64": "npx electron-builder --mac --arm64 -c electron-builder.mac.json --publish never",
    "dist:mac:x64": "npx electron-builder --mac --x64 -c electron-builder.mac.json --publish never",
    "dist:mac:arm64:dev": "SKIP_NOTARIZE=true CSC_IDENTITY_AUTO_DISCOVERY=false npm run dist:mac:arm64",
    "dist:mac:x64:dev": "SKIP_NOTARIZE=true CSC_IDENTITY_AUTO_DISCOVERY=false npm run dist:mac:x64",
    "dist:win:x64": "electron-forge make --platform=win32 --arch=x64",
    "dist:win:arm64": "electron-forge make --platform=win32 --arch=arm64",
    "dist:linux:x64": "npx electron-builder --linux --x64 -c electron-builder.linux.json --publish never",
    "dist:linux:arm64": "npx electron-builder --linux --arm64 -c electron-builder.linux.json --publish never",
    "pear:build:darwin:arm64": "npx pear-build --package=./package.json --darwin-arm64-app ./out/mac-arm64/AlterSend.app --target ../../../altersend-desktop-$npm_package_version",
    "pear:build:darwin:x64": "npx pear-build --package=./package.json --darwin-x64-app ./out/mac/AlterSend.app --target ../../../altersend-desktop-$npm_package_version",
    "pear:build:linux:x64": "npx pear-build --package=./package.json --linux-x64-app ./out/AlterSend-x64.AppImage --target ../../../altersend-desktop-$npm_package_version",
    "pear:build:linux:arm64": "npx pear-build --package=./package.json --linux-arm64-app ./out/AlterSend-arm64.AppImage --target ../../../altersend-desktop-$npm_package_version",
    "pear:build:win:x64": "npx pear-build --package=./package.json --win32-x64-app ./out/AlterSend-win32-x64/AlterSend.msix --target ..\\..\\.\\altersend-desktop-%npm_package_version%"
  },
  "dependencies": {
    "@altersend/components": "1.5.1",
    "@altersend/core": "1.5.1",
    "@altersend/domain": "1.5.1",
    "@altersend/locales": "1.5.1",
    "@sentry/electron": "^7.13.0",
    "b4a": "^1.8.0",
    "bare-rpc": "^1.2.0",
    "corestore": "^7.9.1",
    "electron-squirrel-startup": "^1.0.1",
    "hypercore-crypto": "^3.6.1",
    "hyperdrive": "^13.3.0",
    "hyperswarm": "^4.17.0",
    "lucide-react": "^1.8.0",
    "paparam": "^1.10.0",
    "pear-runtime": "^1.1.1",
    "pear-runtime-updater": "^3.0.10",
    "qr-scanner": "^1.4.2",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "which-runtime": "^1.3.2"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-dmg": "^7.11.2",
    "@electron-forge/maker-msix": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron/notarize": "^2.2.1",
    "@stylexjs/babel-plugin": "^0.15.4",
    "@tailwindcss/vite": "^4.1.13",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/node": "^25.4.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "app-builder-lib": "^26.8.1",
    "dotenv": "^16.6.1",
    "electron": "^40.2.1",
    "electron-builder": "^26.8.1",
    "pear-build": "^1.1.0",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-babel": "^1.6.0"
  }
}
