{
  "expo": {
    "name": "AlterSend",
    "slug": "altersend",
    "version": "1.4.0",
    "newArchEnabled": true,
    "orientation": "portrait",
    "scheme": "altersend",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#16181d"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.altersend.mobile",
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "AlterSend uses your local network to discover nearby devices for peer-to-peer file transfer.",
        "NSBonjourServices": ["_altersend._udp", "_altersend._tcp"],
        "UIFileSharingEnabled": true,
        "LSSupportsOpeningDocumentsInPlace": true,
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleAllowMixedLocalizations": true
      },
      "privacyManifests": {
        "NSPrivacyTracking": false,
        "NSPrivacyCollectedDataTypes": [
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypeCrashData",
            "NSPrivacyCollectedDataTypeLinked": false,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": [
              "NSPrivacyCollectedDataTypePurposeAppFunctionality"
            ]
          },
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypePerformanceData",
            "NSPrivacyCollectedDataTypeLinked": false,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": [
              "NSPrivacyCollectedDataTypePurposeAppFunctionality"
            ]
          },
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypeOtherDiagnosticData",
            "NSPrivacyCollectedDataTypeLinked": false,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": [
              "NSPrivacyCollectedDataTypePurposeAppFunctionality"
            ]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.altersend.mobile",
      "permissions": [
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.ACCESS_WIFI_STATE",
        "android.permission.CHANGE_WIFI_MULTICAST_STATE",
        "android.permission.WAKE_LOCK"
      ],
      "blockedPermissions": [
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO"
      ]
    },
    "plugins": [
      ["expo-router"],
      [
        "@sentry/react-native/expo",
        {
          "organization": "altersend",
          "project": "altersend"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 29,
            "buildArchs": ["arm64-v8a"],
            "enableMinifyInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "AlterSend uses your camera to scan connection QR codes.",
          "microphonePermission": false,
          "recordAudioAndroid": false,
          "barcodeScannerEnabled": true
        }
      ],
      "expo-sharing",
      [
        "expo-media-library",
        {
          "photosPermission": "AlterSend reads your photo library so you can pick photos and videos to send to another device.",
          "savePhotosPermission": "AlterSend saves received images and videos to your photo library.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      [
        "expo-share-intent",
        {
          "iosAppGroupIdentifier": "group.com.altersend.mobile",
          "iosActivationRules": {
            "NSExtensionActivationSupportsImageWithMaxCount": 100,
            "NSExtensionActivationSupportsMovieWithMaxCount": 100,
            "NSExtensionActivationSupportsFileWithMaxCount": 100
          },
          "androidIntentFilters": ["*/*"]
        }
      ],
      [
        "expo-localization",
        {
          "supportedLocales": {
            "ios": [
              "en-US",
              "en-GB",
              "ja-JP",
              "ko-KR",
              "zh-CN",
              "zh-TW",
              "fr-FR",
              "de-DE",
              "it-IT",
              "pt-BR",
              "es-419",
              "es-ES"
            ],
            "android": [
              "en-US",
              "en-GB",
              "ja-JP",
              "ko-KR",
              "zh-CN",
              "zh-TW",
              "fr-FR",
              "de-DE",
              "it-IT",
              "pt-BR",
              "es-419",
              "es-ES"
            ]
          }
        }
      ],
      [
        "expo-font",
        {
          "ios": {
            "fonts": [
              "../../assets/fonts/NotoSans-JP-Regular.ttf",
              "../../assets/fonts/NotoSans-JP-Bold.ttf",
              "../../assets/fonts/NotoSans-KR-Regular.ttf",
              "../../assets/fonts/NotoSans-KR-Bold.ttf",
              "../../assets/fonts/NotoSans-SC-Regular.ttf",
              "../../assets/fonts/NotoSans-SC-Bold.ttf",
              "../../assets/fonts/NotoSans-TC-Regular.ttf",
              "../../assets/fonts/NotoSans-TC-Bold.ttf"
            ]
          },
          "android": {
            "fonts": [
              {
                "fontFamily": "AlterSend Sans JP",
                "fontDefinitions": [
                  {
                    "path": "../../assets/fonts/NotoSans-JP-Regular.ttf",
                    "weight": 400
                  },
                  {
                    "path": "../../assets/fonts/NotoSans-JP-Bold.ttf",
                    "weight": 700
                  }
                ]
              },
              {
                "fontFamily": "AlterSend Sans KR",
                "fontDefinitions": [
                  {
                    "path": "../../assets/fonts/NotoSans-KR-Regular.ttf",
                    "weight": 400
                  },
                  {
                    "path": "../../assets/fonts/NotoSans-KR-Bold.ttf",
                    "weight": 700
                  }
                ]
              },
              {
                "fontFamily": "AlterSend Sans SC",
                "fontDefinitions": [
                  {
                    "path": "../../assets/fonts/NotoSans-SC-Regular.ttf",
                    "weight": 400
                  },
                  {
                    "path": "../../assets/fonts/NotoSans-SC-Bold.ttf",
                    "weight": 700
                  }
                ]
              },
              {
                "fontFamily": "AlterSend Sans TC",
                "fontDefinitions": [
                  {
                    "path": "../../assets/fonts/NotoSans-TC-Regular.ttf",
                    "weight": 400
                  },
                  {
                    "path": "../../assets/fonts/NotoSans-TC-Bold.ttf",
                    "weight": 700
                  }
                ]
              }
            ]
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "3727baf7-0b5c-4e81-97bd-28296124d0c0"
      }
    },
    "locales": {
      "en-US": "./locales/en-US.json",
      "en-GB": "./locales/en-GB.json",
      "ja-JP": "./locales/ja-JP.json",
      "ko-KR": "./locales/ko-KR.json",
      "zh-CN": "./locales/zh-CN.json",
      "zh-TW": "./locales/zh-TW.json",
      "fr-FR": "./locales/fr-FR.json",
      "de-DE": "./locales/de-DE.json",
      "it-IT": "./locales/it-IT.json",
      "pt-BR": "./locales/pt-BR.json",
      "es-419": "./locales/es-419.json",
      "es-ES": "./locales/es-ES.json"
    }
  }
}
