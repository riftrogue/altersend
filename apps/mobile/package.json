{
  "private": true,
  "name": "@altersend/mobile",
  "version": "1.5.0",
  "description": "AlterSend mobile app (React Native / Expo)",
  "main": "expo-router/entry",
  "scripts": {
    "build:packages": "cd ../.. && npm run build -w packages/core && npm run build -w packages/locales && npm run build -w packages/domain && npm run build -w packages/components",
    "prestart": "npm run build:packages && npm run bundle-bare",
    "start": "expo start --dev-client",
    "postinstall": "npm run barekit:link-ios-addons && npm run barekit:link-android-addons",
    "eas-build-post-install": "cd ../.. && npm run build -w packages/core && npm run build -w packages/locales && npm run build -w packages/domain && npm run build -w packages/components && npm run bundle-bare -w apps/mobile",
    "barekit:link-ios-addons": "node ./scripts/link-ios-addons.cjs",
    "barekit:link-android-addons": "node ./scripts/link-android-addons.cjs",
    "pods:install": "cd ios && LANG=en_US.UTF-8 pod install",
    "preandroid": "npm run build:packages && npm run bundle:android",
    "android": "expo run:android",
    "preios": "npm run build:packages && npm run bundle:ios",
    "ios": "expo run:ios",
    "bundle:android": "bare-pack --host android-arm64 --host android-arm --host android-ia32 --host android-x64 --linked --out bundles/app-android.bundle.js ../../packages/core/dist/worklet/index.js",
    "bundle:ios": "bare-pack --host ios-arm64 --host ios-arm64-simulator --host ios-x64-simulator --linked --out bundles/app-ios.bundle.js ../../packages/core/dist/worklet/index.js",
    "bundle-bare": "npm run bundle:android && npm run bundle:ios",
    "typecheck": "tsc --noEmit",
    "build:apk": "eas build --platform android --profile preview",
    "build:apk:local": "npm run bundle:android && cd android && ./gradlew assembleRelease"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/denislupookov/altersend.git"
  },
  "author": "AlterSend",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/denislupookov/altersend/issues"
  },
  "homepage": "https://github.com/denislupookov/altersend#readme",
  "dependencies": {
    "@altersend/components": "1.5.0",
    "@altersend/core": "1.5.0",
    "@altersend/domain": "1.5.0",
    "@altersend/locales": "1.5.0",
    "@expo/vector-icons": "^15.0.2",
    "@sentry/react-native": "^8.11.0",
    "b4a": "^1.6.7",
    "expo": "~55.0.15",
    "expo-blur": "~55.0.14",
    "expo-build-properties": "~55.0.9",
    "expo-camera": "~55.0.13",
    "expo-clipboard": "~55.0.13",
    "expo-constants": "~55.0.7",
    "expo-document-picker": "~55.0.13",
    "expo-file-system": "~55.0.16",
    "expo-font": "~55.0.7",
    "expo-haptics": "~15.0.7",
    "expo-image-picker": "~55.0.18",
    "expo-linking": "~55.0.13",
    "expo-localization": "~55.0.15",
    "expo-media-library": "~55.0.15",
    "expo-router": "~55.0.5",
    "expo-secure-store": "~55.0.0",
    "expo-share-intent": "^6.1.0",
    "expo-sharing": "~55.0.18",
    "expo-splash-screen": "~55.0.21",
    "expo-system-ui": "~55.0.9",
    "lucide-react-native": "^1.8.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-b4a": "^0.0.4",
    "react-native-bare-kit": "^0.14.0",
    "react-native-qrcode-svg": "^6.3.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-strict-dom": "^0.0.55"
  },
  "devDependencies": {
    "@types/react": "~19.2.10",
    "bare-pack": "^2.0.1",
    "react-native-svg-transformer": "^1.5.3",
    "typescript": "^5.3.3"
  }
}
