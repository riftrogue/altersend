{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": ["scripts/*.{js,cjs,mjs}"],
      "project": ["scripts/**/*.{js,cjs,mjs}"],
      "ignoreDependencies": [
        "expo",
        "react-dom"
      ]
    },
    "packages/core": {
      "entry": ["src/**/*.test.ts"]
    },
    "packages/domain": {
      "entry": ["src/**/*.test.ts"]
    },
    "packages/locales": {
      "entry": ["src/**/*.test.ts"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/components": {
      "entry": [
        "scripts/*.mjs",
        ".storybook/{main,preview}.{ts,tsx}",
        "src/**/*.stories.{ts,tsx}"
      ],
      "project": ["src/**/*.{ts,tsx}", "scripts/**/*.mjs"],
      "ignoreDependencies": ["lucide-react", "lucide-react-native"],
      "ignoreUnresolved": [
        "^\\./DragSurface$",
        "^\\./useIconColor$",
        "^\\./lucide$"
      ]
    },
    "apps/desktop": {
      "entry": [
        "src/electron/main.ts",
        "src/electron/preload.cjs",
        "scripts/*.{js,cjs,mjs}",
        "forge.config.{js,cjs,mjs}",
        "vite.config.{ts,js,mjs}"
      ],
      "project": [
        "src/**/*.{ts,tsx,cjs}",
        "scripts/**/*.{js,cjs,mjs}"
      ],
      "ignoreDependencies": [
        "b4a",
        "bare-rpc",
        "corestore",
        "hypercore-crypto",
        "hyperdrive",
        "hyperswarm",
        "pear-runtime-updater",
        "@electron-forge/maker-dmg",
        "@electron-forge/maker-msix",
        "@electron-forge/maker-squirrel",
        "app-builder-lib"
      ],
      "ignoreUnresolved": [
        "^\\./sentry-dsn\\.gen\\.js$"
      ],
      "ignoreBinaries": [
        "electron-builder.mac.json",
        "electron-builder.linux.json"
      ]
    },
    "apps/mobile": {
      "entry": [
        "app/**/*.{ts,tsx}",
        "src/**/*.{ts,tsx}",
        "scripts/*.{js,cjs,mjs}",
        "metro.config.{js,cjs}",
        "babel.config.{js,cjs}"
      ],
      "project": [
        "app/**/*.{ts,tsx}",
        "src/**/*.{ts,tsx}",
        "scripts/**/*.{js,cjs,mjs}"
      ],
      "ignoreDependencies": [
        "b4a",
        "react-native-b4a",
        "react-strict-dom",
        "expo-updates"
      ],
      "ignoreBinaries": ["eas"]
    }
  },
  "ignoreBinaries": ["pod"],
  "rules": {
    "duplicates": "off"
  }
}
