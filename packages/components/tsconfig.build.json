{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "emitDeclarationOnly": false,
    "declaration": true,
    "outDir": "dist",
    "jsx": "react-jsx",
    "noEmitOnError": true,
    "moduleSuffixes": [".web", ""]
  },
  "include": ["src/**/*"],
  "exclude": [
    "src/**/*.test.tsx",
    "src/**/*.test.ts",
    "src/**/*.stories.tsx",
    "src/**/__tests__/**/*"
  ]
}
